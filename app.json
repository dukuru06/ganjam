{
  "expo": {
    "name": "Ganjam Tournament",
    "slug": "arena-esports",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0A12",
    "icon": "./assets/icon.png",
    "splash": {
      "backgroundColor": "#0A0A12",
      "resizeMode": "contain"
    },
    "android": {
      "package": "com.arena.esports",
      "versionCode": 1,
      "permissions": [
        "NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A12"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-notifications",
      "expo-asset",
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "kotlinVersion": "1.9.25"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "bd1c0a57-a295-4835-96c0-7f0b963b898d"
      }
    },
    "owner": "dukuru"
  }
}
